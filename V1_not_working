import sys
import math
from collections import deque

# fonction de simulation de mouvement
def move_snake(body, direction):

    dx, dy = direction
    hx, hy = body[0]

    new_head = (hx+dx, hy+dy)

    new_body = [new_head] + body[:-1]

    return new_body

# fonction pour appliquer la gravité sur une coord
def apply_gravity(body, grid, height):

    if is_supported(body, grid, height):
        return body

    fallen = [(x, y+1) for x, y in body]

    while not is_supported(fallen, grid, height):

        new = []
        for x, y in fallen:
            if y+1 >= height:
                return None  # snake tombe hors map
            new.append((x, y+1))

        fallen = new

    return fallen

# fonction qui vérifie si des coordonnées sont dans les limites
def in_bounds(x, y):
    return 0 <= x < width and 0 <= y < height

# fonction vérifiant la solidité d'une case
def is_solid(x, y, grid):
    return grid[y][x] == '#'

# fonction pour vérifier si le snake est soutenu
def is_supported(body, grid, height):
    for x, y in body:
        if y+1 < height and grid[y+1][x] == '#':
            return True
    return False

# fonction pour trouver la distance vers une source
def bfs_distance(start_body, target, grid, width, height):

    queue = deque()
    visited = set()

    queue.append((start_body, 0))
    visited.add(tuple(start_body))

    while queue:

        body, dist = queue.popleft()

        if body[0] == target:
            return dist

        for dx, dy in [(1,0),(-1,0),(0,1),(0,-1)]:

            new_body = move_snake(body, (dx,dy))
            hx, hy = new_body[0]

            if not (0 <= hx < width and 0 <= hy < height):
                continue

            if grid[hy][hx] in ['#','o','0']:
                continue

            new_body = apply_gravity(new_body, grid, height)

            if new_body is None:
                continue

            key = tuple(new_body)

            if key in visited:
                continue

            visited.add(key)
            queue.append((new_body, dist + 1))

    return None

# fonction pour assigner des sources à mes snakes
def assign_targets(snakes, my_snakes, power_sources, grid, width, height):

    assignments = {}
    available_sources = set(power_sources)

    for snake_id in my_snakes:

        if snake_id not in snakes:
            continue

        head = snakes[snake_id][0]

        best_source = None
        best_dist = 10**9

        for source in available_sources:

            dist = bfs_distance(head, source, grid, width, height)

            if dist is not None and dist < best_dist:
                best_dist = dist
                best_source = source

        if best_source:
            assignments[snake_id] = best_source
            available_sources.remove(best_source)

    return assignments

